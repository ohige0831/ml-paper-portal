# Copy this file as reference for required secrets.
# Actual values are set via: wrangler secret put <KEY_NAME>
# Do NOT create a .env file with real values.

# Required: OpenAI API key for Japanese summary generation
OPENAI_API_KEY=sk-...

# Required: Password for the admin panel (Basic Auth)
ADMIN_PASSWORD=your-strong-password-here

# Optional: OpenAI model to use (default: gpt-4o-mini)
OPENAI_MODEL=gpt-4o-mini

# Optional: Public site URL shown in admin panel links
SITE_BASE_URL=https://your-pages-domain.pages.dev
